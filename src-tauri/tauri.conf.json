{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zudo-file-viewer",
  "version": "0.1.0",
  "identifier": "com.zudolab.file-viewer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "zudo-file-viewer",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
